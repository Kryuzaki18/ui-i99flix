# i99flix React App — environment variables
# Copy this file to .env and fill in your values

# TMDB Read Access Token (from https://www.themoviedb.org/settings/api)
VITE_TMDB_READ_TOKEN=your_tmdb_read_access_token_here

# TMDB API base URL (optional — defaults to https://api.themoviedb.org/3)
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3

# i99flix backend API base URL
VITE_API_BASE_URL=http://localhost:4321/api/v1
